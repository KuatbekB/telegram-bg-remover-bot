BOT_TOKEN=123456789:replace_with_token_from_botfather
BOT_NAME=ФонOFF
REQUIRE_CHANNEL_SUBSCRIPTION=false
REQUIRED_CHANNEL=@superski9
REQUIRED_CHANNEL_URL=https://t.me/superski9
PRIVACY_CONTACT=@superski9
PRIVACY_POLICY_URL=https://telegram.org/privacy-tpa

# Optional settings
REMBG_MODEL=u2net
RETRY_REMBG_MODEL=isnet-general-use
PRELOAD_MODELS=false
PRELOAD_PRIMARY_MODEL=true
OMP_NUM_THREADS=2
ALPHA_MATTING=false
POST_PROCESS_MASK=true
ALPHA_MATTING_FOREGROUND_THRESHOLD=240
ALPHA_MATTING_BACKGROUND_THRESHOLD=10
ALPHA_MATTING_ERODE_SIZE=10
# Must remain false: this build intentionally does not persist unencrypted user images.
SAVE_DEBUG_IMAGES=false
INSTANCE_LOCK_FILE=telegram-bg-remover.lock
READY_FILE=telegram-bg-remover-ready
HEARTBEAT_FILE=telegram-bg-remover-heartbeat
HEALTH_HEARTBEAT_SECONDS=10
REMOVE_WHITE_REMNANTS=false
WHITE_REMNANT_THRESHOLD=245
EDGE_FEATHER_RADIUS=0.4
MAX_DOWNLOAD_BYTES=20971520
MAX_OUTPUT_BYTES=51380224
MAX_IMAGE_PIXELS=12000000
MAX_CONCURRENT_JOBS=2
MAX_QUEUE_SIZE=20
UPDATE_CONCURRENCY=32
USER_COOLDOWN_SECONDS=3
USER_RATE_LIMIT_COUNT=5
USER_RATE_LIMIT_WINDOW_SECONDS=60
PROCESSING_TIMEOUT_SECONDS=120
PROGRESS_UPDATE_SECONDS=4
TELEGRAM_MAX_RETRIES=2
TELEGRAM_RETRY_BASE_SECONDS=1
RETRY_DATA_TTL_SECONDS=3600
PRIVACY_CLEANUP_INTERVAL_SECONDS=60
LOG_LEVEL=INFO
